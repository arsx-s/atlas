# =============================================================================
# Atlas - Production Environment Configuration
# =============================================================================
# Copy this file to .env.prod and fill in all secrets before deployment.
#   cp .env.prod.example .env.prod
# DO NOT commit .env.prod to version control.
# =============================================================================

# --- Application ---
ATLAS_APP_NAME=Atlas
ATLAS_ENV=production
ATLAS_RUNTIME_MODE=hybrid
ATLAS_API_VERSION=v1
ATLAS_API_BASE_PATH=/api/v1
ATLAS_API_BASE_URL=https://api.atlaslabs.app/api/v1
ATLAS_HTTPS_ONLY=true

# --- Logging ---
ATLAS_LOG_LEVEL=info

# --- CORS ---
ATLAS_CORS_ALLOWED_ORIGINS=https://atlaslabs.ai,https://www.atlaslabs.ai,https://atlaslabs.app

# --- Security ---
ATLAS_RATE_LIMIT_ENABLED=true

# --- Auth ---
# Generate a secure random secret: python -c "import secrets; print(secrets.token_urlsafe(48))"
# DO NOT share this secret. Rotate periodically.
ATLAS_JWT_SECRET=

# --- Database ---
# SQLite (single-instance, data persisted in Docker volume)
ATLAS_SQLITE_PATH=/data/atlas-local.db

# PostgreSQL (recommended for multi-instance production)
# DATABASE_URL=postgresql://user:password@postgres:5432/atlas

# --- Cache & Vector Store ---
# REDIS_URL=redis://redis:6379/0
# QDRANT_URL=http://qdrant:6333
# NEO4J_URL=bolt://neo4j:7687

# --- Storage ---
ATLAS_STORAGE_TYPE=filesystem
ATLAS_STORAGE_PATH=/data/storage
# AWS_S3_BUCKET=atlas-storage-prod
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...

# --- Documents ---
ATLAS_DOCUMENTS_PATH=/data/documents
ATLAS_MAX_DOCUMENT_SIZE_MB=100
ATLAS_OCR_PROVIDER=tesseract
ATLAS_CHUNKING_STRATEGY=semantic
ATLAS_CHUNK_MIN_SIZE=100
ATLAS_CHUNK_MAX_SIZE=2000

# --- Knowledge Graph ---
ATLAS_KNOWLEDGE_GRAPH_ENABLED=false

# --- Local AI ---
ATLAS_LOCAL_MODE_ENABLED=false
ATLAS_LOCAL_MODELS_ENABLED=false

# =============================================================================
# REQUIRED: AI Provider API Keys
# =============================================================================
# At least one provider must be configured for AI research to work.

# --- OpenAI ---
# OPENAI_API_KEY=sk-proj-...

# --- Anthropic ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Google / Gemini ---
# GOOGLE_API_KEY=AIzaSy...

# --- DeepSeek ---
# DEEPSEEK_API_KEY=sk-...

# =============================================================================
# OPTIONAL: Search Provider API Keys
# =============================================================================
# At least one search provider is recommended for web research.

# --- Tavily ---
# TAVILY_API_KEY=tvly-...

# --- Brave ---
# BRAVE_API_KEY=...

# =============================================================================
# Sync
# =============================================================================
ATLAS_CLOUD_SYNC_ENABLED=false
