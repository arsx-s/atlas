# =============================================================================
# Atlas - Environment Configuration
# =============================================================================
# Copy this file to .env and customize for your environment.
#   cp .env.example .env
# =============================================================================

# --- Application ---
ATLAS_APP_NAME=Atlas API
ATLAS_ENV=development
ATLAS_RUNTIME_MODE=hybrid           # local | cloud | hybrid
ATLAS_API_VERSION=v1
ATLAS_API_BASE_PATH=/api/v1
ATLAS_API_BASE_URL=http://localhost:8000/api/v1
ATLAS_HTTPS_ONLY=false

# --- Logging ---
ATLAS_LOG_LEVEL=debug                # debug | info | warning | error | critical

# --- CORS ---
ATLAS_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173,http://127.0.0.1:5173,http://localhost:8000,http://localhost:80

# --- Security ---
ATLAS_RATE_LIMIT_ENABLED=true          # 100 req/hour per IP

# --- Auth ---
# Generate a secret: python -c "import secrets; print(secrets.token_urlsafe(48))"
ATLAS_JWT_SECRET=

# --- Database ---
# SQLite (default, no additional setup required)
ATLAS_SQLITE_PATH=atlas-local.db

# PostgreSQL (optional, for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/atlas

# --- Cache & Vector Store ---
# REDIS_URL=redis://localhost:6379/0
# QDRANT_URL=http://localhost:6333
# NEO4J_URL=bolt://localhost:7687

# --- Storage ---
ATLAS_STORAGE_TYPE=filesystem        # filesystem | s3
ATLAS_STORAGE_PATH=./storage
# AWS_S3_BUCKET=atlas-storage

# --- Documents ---
ATLAS_DOCUMENTS_PATH=./documents
ATLAS_MAX_DOCUMENT_SIZE_MB=100
ATLAS_OCR_PROVIDER=tesseract         # tesseract | cloud
ATLAS_CHUNKING_STRATEGY=semantic     # semantic | sliding_window
ATLAS_CHUNK_MIN_SIZE=100
ATLAS_CHUNK_MAX_SIZE=2000

# --- Knowledge Graph ---
ATLAS_KNOWLEDGE_GRAPH_ENABLED=false

# --- Local AI (Ollama) ---
ATLAS_LOCAL_MODE_ENABLED=true
ATLAS_LOCAL_MODELS_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
ATLAS_LOCAL_EMBEDDING_MODEL=nomic-embed-text
ATLAS_LOCAL_LLM_MODEL=mistral-7b
ATLAS_LOCAL_CACHE_MAX_SIZE=1000
ATLAS_LOCAL_MEMORY_MAX_ENTRIES=10000

# --- AI Providers ---
# OpenAI
# OPENAI_API_KEY=

# Anthropic
# ANTHROPIC_API_KEY=

# Google / Gemini
# GOOGLE_API_KEY=

# DeepSeek
# DEEPSEEK_API_KEY=

# --- Search Providers ---
# TAVILY_API_KEY=
# BRAVE_API_KEY=

# --- Frontend (Vite dev server) ---
# ATLAS_API_PROXY_TARGET=http://127.0.0.1:8000

# --- Frontend (Build-time API URL) ---
# VITE_ATLAS_API_BASE_URL=http://localhost:8000/api/v1

# --- Sync ---
ATLAS_CLOUD_SYNC_ENABLED=false
